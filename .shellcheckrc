# Allow shellcheck to follow non-constant `source` directives
external-sources=true

# Enable optional checks that catch real bugs.
# NOT enabled: check-extra-masked-returns (SC2312) and
# check-set-e-suppressed (SC2310) — these fire on legitimate graceful-
# fallback patterns (e.g., dispatcher trying multiple paths, theme
# system trying fallback chains). Sprinkling per-line disables across
# every such pattern is uglier than dropping the rules.
enable=add-default-case
enable=avoid-nullary-conditions
enable=check-unassigned-uppercase
enable=deprecate-which
enable=quote-safe-variables
enable=require-variable-braces
