#!/usr/bin/env bash
# paco:summary=Create a desktop launcher for a web app
# paco:args=[name url icon [custom-exec] [mime-types]]

set -euo pipefail

ICON_DIR="${HOME}/.local/share/applications/icons"
DESKTOP_DIR="${HOME}/.local/share/applications"

mkdir -p "${ICON_DIR}"
mkdir -p "${DESKTOP_DIR}"

if (($# < 3)); then
  # Interactive mode: prompt for name + URL, try favicon, then create.
  echo -e "\e[32mLet's create a new web app you can launch from Vicinae.\n\e[0m"
  APP_NAME="$(gum input --prompt "Name> " --placeholder "My favorite web app")"
  APP_URL="$(gum input --prompt "URL> " --placeholder "https://example.com")"

  if [[ ! ${APP_URL} =~ ^[a-zA-Z][a-zA-Z0-9+.-]*: ]]; then
    APP_URL="https://${APP_URL}"
  fi

  # Try Google's favicon service first; fall back to user-supplied URL.
  FAVICON_URL="https://www.google.com/s2/favicons?domain=${APP_URL}&sz=128"
  if curl -fsSL -o "${ICON_DIR}/${APP_NAME}.png" "${FAVICON_URL}" &&
    [[ -s "${ICON_DIR}/${APP_NAME}.png" ]]; then
    ICON_REF="${APP_NAME}.png"
  else
    ICON_REF="$(gum input --prompt "Icon URL> " --placeholder "Favicon fetch failed. Enter a PNG icon URL (see https://dashboardicons.com)")"
  fi

  CUSTOM_EXEC=""
  MIME_TYPES=""
  INTERACTIVE_MODE=true
else
  APP_NAME="$1"
  APP_URL="$2"

  if [[ ! ${APP_URL} =~ ^[a-zA-Z][a-zA-Z0-9+.-]*: ]]; then
    APP_URL="https://${APP_URL}"
  fi

  ICON_REF="$3"
  CUSTOM_EXEC="${4:-}" # Optional: custom Exec= line (used for URL handlers)
  MIME_TYPES="${5:-}"  # Optional: MimeType= line (also URL handlers)
  INTERACTIVE_MODE=false
fi

if [[ -z ${APP_NAME} || -z ${APP_URL} ]]; then
  echo "paco-webapp-install: name and URL are required." >&2
  exit 1
fi

# Resolve icon: download if URL, else assume it's a filename under
# the icons dir.
if [[ -z ${ICON_REF} ]]; then
  ICON_REF="https://www.google.com/s2/favicons?domain=${APP_URL}&sz=128"
fi

if [[ ${ICON_REF} =~ ^https?:// ]]; then
  ICON_PATH="${ICON_DIR}/${APP_NAME}.png"
  if ! curl -fsSL -o "${ICON_PATH}" "${ICON_REF}" || [[ ! -s ${ICON_PATH} ]]; then
    echo "paco-webapp-install: failed to download icon from ${ICON_REF}" >&2
    exit 1
  fi
else
  ICON_PATH="${ICON_DIR}/${ICON_REF}"
fi

# Use an absolute path so the .desktop file works regardless of the
# launcher's PATH (Vicinae, Hyprland exec, GNOME Shell, etc. all read
# .desktop Exec= via their own exec context, which may not include
# /usr/share/paco/bin even when environment.d does propagate). The
# default callers stick to paco-launch-webapp; URL handlers (Zoom)
# pass their own absolute path in CUSTOM_EXEC.
EXEC_COMMAND="${CUSTOM_EXEC:-/usr/share/paco/bin/paco-launch-webapp ${APP_URL}}"

DESKTOP_FILE="${DESKTOP_DIR}/${APP_NAME}.desktop"

cat > "${DESKTOP_FILE}" << EOF
[Desktop Entry]
Version=1.0
Name=${APP_NAME}
Comment=${APP_NAME}
Exec=${EXEC_COMMAND}
Terminal=false
Type=Application
Icon=${ICON_PATH}
StartupNotify=true
EOF

if [[ -n ${MIME_TYPES} ]]; then
  echo "MimeType=${MIME_TYPES}" >> "${DESKTOP_FILE}"
fi

chmod +x "${DESKTOP_FILE}"

if [[ ${INTERACTIVE_MODE} == "true" ]]; then
  echo -e "Installed ${APP_NAME}. Open with Super+Space → '${APP_NAME}'.\n"
fi
