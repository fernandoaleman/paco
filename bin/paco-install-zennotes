#!/usr/bin/env bash
# paco:summary=Install ZenNotes — keyboard-first Markdown notes (Obsidian alternative)

set -euo pipefail

if paco-pkg-present zennotes-bin; then
  echo "zennotes-bin is already installed."
  echo "Launch from Vicinae: Super+Space → ZenNotes"
  exit 0
fi

paco-pkg-aur-add zennotes-bin

cat << EOF

ZenNotes installed.

  - Launch from Vicinae: Super+Space → ZenNotes
  - ZenNotes uses plain Markdown files, so you can point it at an
    existing Obsidian vault and try both side-by-side.
  - The 'zen' CLI installs from inside the app: Settings → CLI.

EOF
