#!/usr/bin/env bash
# paco:summary=Remove web app desktop launchers (interactive picker if no args)
# paco:args=[name...]

set -euo pipefail

ICON_DIR="${HOME}/.local/share/applications/icons"
DESKTOP_DIR="${HOME}/.local/share/applications"

if (($# == 0)); then
  # No args: scan the desktop dir for webapps, gum-pick the ones to drop.
  WEB_APPS=()
  while IFS= read -r -d '' file; do
    if grep -qE '^Exec=.*(paco-launch-webapp|paco-webapp-handler)' "${file}"; then
      WEB_APPS+=("$(basename "${file%.desktop}")")
    fi
  done < <(find "${DESKTOP_DIR}" -maxdepth 1 -name '*.desktop' -print0)

  if ((${#WEB_APPS[@]} == 0)); then
    echo "No web apps to remove."
    exit 1
  fi

  IFS=$'\n' read -r -d '' -a SORTED_WEB_APPS < <(printf '%s\n' "${WEB_APPS[@]}" | sort && printf '\0')

  APP_NAMES_STRING="$(gum choose --no-limit --header "Select web app(s) to remove..." --selected-prefix="✗ " "${SORTED_WEB_APPS[@]}")"

  APP_NAMES=()
  while IFS= read -r line; do
    [[ -n ${line} ]] && APP_NAMES+=("${line}")
  done <<< "${APP_NAMES_STRING}"
else
  APP_NAMES=("$@")
fi

if ((${#APP_NAMES[@]} == 0)); then
  echo "paco-webapp-remove: select at least one web app to remove." >&2
  exit 1
fi

for APP_NAME in "${APP_NAMES[@]}"; do
  rm -f "${DESKTOP_DIR}/${APP_NAME}.desktop"
  rm -f "${ICON_DIR}/${APP_NAME}.png"
  echo "Removed ${APP_NAME}"
done

# Refresh Vicinae so the launcher drops the removed entries.
if command -v paco-restart-vicinae > /dev/null 2>&1; then
  paco-restart-vicinae
fi
