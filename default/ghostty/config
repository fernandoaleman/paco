# paco ghostty config — Q10 baseline + Hyprland tuning.
# Theme colors come from ~/.config/paco/current/theme/ghostty.conf
# (rendered from default/themed/ghostty.conf.tpl by `paco theme-set`).

config-file = ~/.config/paco/current/theme/ghostty.conf

font-family = JetBrainsMono Nerd Font
font-size = 14

copy-on-select = clipboard
shell-integration = detect
mouse-hide-while-typing = true
background-opacity = 0.9
window-padding-x = 25
window-padding-y = 20

# Hyprland slowness fix (ghostty discussion #3224)
async-backend = epoll

# Claude Code multi-line input (shift+enter sends ESC + CR)
keybind = shift+enter=text:\x1b\r

# Explicit clipboard keybinds (ghostty defaults — made explicit)
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Theme — wired above via config-file directive (iter 17).
