# paco mako config — notification daemon for Wayland.
# Theme colors come from ~/.config/paco/current/theme/mako.ini
# (rendered from default/themed/mako.ini.tpl by `paco theme-set`).

include=~/.config/paco/current/theme/mako.ini

anchor=top-right
group-by=app-name,summary,body
default-timeout=5000
width=420
outer-margin=20
padding=10,15
border-size=2
max-icon-size=32
font=sans-serif 14px

[mode=do-not-disturb]
invisible=true

[mode=do-not-disturb app-name=notify-send]
invisible=false

[urgency=critical]
default-timeout=0
layer=overlay

# Spotify spams a notification for every track change — universally
# unwanted. Carried over from omarchy as a distro-level fix.
[app-name=Spotify]
invisible=1
